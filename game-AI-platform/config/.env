
# =============================================================================
#  Provider selection
#
#  Two independent SDK paths are supported:
#
#  1. OpenAI SDK  — set OPENAI_API_KEY  (+ optional OPENAI_BASE_URL)
#                   Used for: Kimi/Moonshot, DeepSeek (OpenAI-compat), etc.
#                   This path is chosen whenever OPENAI_API_KEY is set.
#
#  2. Anthropic SDK — set ANTHROPIC_API_KEY (+ optional ANTHROPIC_BASE_URL)
#                   Used for: Anthropic Claude, MiniMax, GLM, etc.
#                   This path is the fallback when OPENAI_API_KEY is not set.
#
#  You only need ONE set of credentials.
# =============================================================================

# ── Option A: Anthropic SDK (Claude and Anthropic-compatible providers) ──────

# API Key (required for Anthropic path)
# Get yours at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=94816a92-cabc-4e70-96f2-a53c0e3cda27

# Model ID (required)
MODEL_ID=mcs-1

# Base URL (optional, for Anthropic-compatible providers)
# ANTHROPIC_BASE_URL=https://kspmas.ksyun.com/v1

# ── Option B: OpenAI SDK (Kimi / Moonshot and other OpenAI-compat providers) ─

# API Key (required for OpenAI path — takes priority over Anthropic path)
OPENAI_API_KEY=94816a92-cabc-4e70-96f2-a53c0e3cda27

# Base URL (required for non-OpenAI providers)
OPENAI_BASE_URL=https://kspmas.ksyun.com/v1

# =============================================================================
#  Provider reference table
#
#  Provider         MODEL_ID              SWE-bench  TB2     SDK    Base URL
#  ---------------  --------------------  ---------  ------  -----  -------------------
#  Anthropic        claude-sonnet-4-6     79.6%      59.1%   anthr  (default)
#  MiniMax          MiniMax-M2.5          80.2%        -     anthr  see below
#  GLM (Zhipu)      glm-5                77.8%        -     anthr  see below
#  Kimi (Moonshot)  kimi-k2.5            76.8%        -     openai see below  ← recommended
#  DeepSeek         deepseek-chat        73.0%        -     openai see below
#                   (V3.2)
#
#  SWE-bench = SWE-bench Verified (Feb 2026)
#  TB2       = Terminal-Bench 2.0 (Feb 2026)
#  SDK       = anthr (Anthropic SDK) | openai (OpenAI SDK)
# =============================================================================

# ---- Anthropic SDK providers (set ANTHROPIC_API_KEY) ----

# MiniMax          https://www.minimax.io
# ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
# MODEL_ID=MiniMax-M2.5

# GLM (Zhipu)      https://z.ai
# ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
# MODEL_ID=glm-5

# ---- OpenAI SDK providers (set OPENAI_API_KEY + OPENAI_BASE_URL) ----

# Kimi (Moonshot)  https://platform.moonshot.ai  (international)
# OPENAI_API_KEY=sk-your-moonshot-key
# OPENAI_BASE_URL=https://api.moonshot.ai/v1
# MODEL_ID=kimi-k2.5
# LLM_TEMPERATURE=1   # kimi-k2.5 only accepts temperature=1

# Kimi (Moonshot)  https://platform.moonshot.cn  (China mainland)
# OPENAI_API_KEY=sk-WFfHACSl1JJ2FmIUEWEpv7n6OcxefyyYo2egfFPH9jkvP2z5
# OPENAI_BASE_URL=https://api.moonshot.cn/v1
# MODEL_ID=kimi-k2.5
# LLM_TEMPERATURE=1

# DeepSeek         https://platform.deepseek.com
# OPENAI_API_KEY=sk-your-deepseek-key
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# MODEL_ID=deepseek-chat

# ---- Anthropic SDK Kimi (legacy, not recommended — pydantic schema mismatch) ----

# Kimi (Moonshot)  https://platform.moonshot.ai  (Anthropic-compat path)
# ANTHROPIC_BASE_URL=https://api.moonshot.ai/anthropic
# MODEL_ID=kimi-k2.5

# ---- China mainland Anthropic SDK providers ----

# MiniMax          https://platform.minimax.io
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
# MODEL_ID=MiniMax-M2.5

# GLM (Zhipu)      https://open.bigmodel.cn
# ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
# MODEL_ID=glm-5

# =============================================================================
#  Other settings (usually no need to change)
# =============================================================================

APP_ENV=dev
# Set to DEBUG to enable full pipeline tracing:
#   - LLM request messages + response text
#   - CLI command lines + stdout/stderr for every npm/node call
#   - Pipeline step entry/exit events
LOG_LEVEL=DEBUG
# LOG_LEVEL=INFO
LOG_FORMAT=text
API_PREFIX=/api/v1
DATA_ROOT=data

# =============================================================================
#  LLM token limits
#
#  LLM_MAX_TOKENS      — default max_tokens for all LLM calls (default: 8192)
#  LLM_CODE_MAX_TOKENS — max_tokens for code/asset/audio generation, which
#                        produces large JSON payloads with complete JS files.
#                        Set higher if responses are still being truncated.
#                        (default: 8192)
#
#  Note: many Anthropic-compatible providers cap output at 8192 tokens.
#  Check your provider's documentation and increase accordingly.
# =============================================================================
# LLM_MAX_TOKENS=8192
LLM_CODE_MAX_TOKENS=16384

# =============================================================================
#  LLM temperature
#
#  LLM_TEMPERATURE — override the sampling temperature for every LLM call.
#                    When unset the default per-call value (0.2) is used.
#
#  kimi-k2.5 only accepts temperature=1; set this when using that model:
# =============================================================================
# LLM_TEMPERATURE=1
